// js/feature3-seokjeok.js
class SeokjeokFeature {
    constructor() {
        this.handSigns = [
            { name: '합장', description: '두 손을 마주 보게 모아 정성스러운 의미를 표현', threshold: 0.8 },
            { name: '손가락', description: '손가락으로 숫자나 모양을 표현', threshold: 0.7 },
            { name: '주먹', description: '손을 주먹으로 쥐는 자세', threshold: 0.75 },
            { name: '펼침', description: '손을 펴서 개방적인 제스처', threshold: 0.7 }
        ];
        this.init();
    }
    
    async init() {
        const hands = new Hands({ locateFile: (f) => `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${f}` });
        hands.setOptions({ maxNumHands: 1, minDetectionConfidence: 0.5 });
        hands.onResults(this.onResults.bind(this));
        
        const video = document.getElementById('webcam');
        navigator.mediaDevices.getUserMedia({ video: true })
            .then(stream => { video.srcObject = stream; })
            .then(() => {
                video.addEventListener('play', async () => {
                    const loop = async () => {
                        if (video.readyState >= 2) await hands.send({ image: video });
                        requestAnimationFrame(loop);
                    };
                    loop();
                });
            });
    }
    
    onResults(results) {
        const container = document.getElementById('feature-container');
        container.innerHTML = '';
        
        if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
            const landmarks = results.multiHandLandmarks[0];
            const sign = this.recognizeHandSign(landmarks);
            
            const resultDiv = document.createElement('div');
            resultDiv.className = 'sign-result';
            resultDiv.innerHTML = `
                <h3>인식된 수인: ${sign.name}</h3>
                <p>${sign.description}</p>
                <canvas id="hand-canvas"></canvas>
            `;
            container.appendChild(resultDiv);
        }
    }
    
    recognizeHandSign(landmarks) {
        // 엄지와 검지 거리 계산
        const thumbTip = landmarks[4];
        const indexTip = landmarks[8];
        const distance = Math.sqrt(
            Math.pow(thumbTip.x - indexTip.x, 2) + 
            Math.pow(thumbTip.y - indexTip.y, 2)
        );
        
        // 손가락 개수 세기
        let fingersUp = 0;
        const fingerTips = [8, 12, 16, 20];
        const fingerJoints = [5, 9, 13, 17];
        
        for (let i = 0; i < 4; i++) {
            if (landmarks[fingerTips[i]].y < landmarks[fingerJoints[i]].y) {
                fingersUp++;
            }
        }
        
        // 수인 판단 로직
        if (distance < 0.1) return this.handSigns[0]; // 합장
        if (fingersUp === 4) return this.handSigns[3]; // 펼침
        if (fingersUp === 0) return this.handSigns[2]; // 주먹
        
        return this.handSigns[1]; // 기타
    }
}
