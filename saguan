// js/feature6-sagwan-llm.js
class SagwanLLM {
    constructor() {
        this.conversation = [];
        this.template = '';
        this.init();
    }
    
    async init() {
        this.renderUI();
        this.setupEventListeners();
    }
    
    renderUI() {
        const container = document.getElementById('feature-container');
        container.innerHTML = `
            <div class="sagwan-chat">
                <div class="chat-history" id="chat-history">
                    <div class="system-message">
                        <h3>📜 사관 LLM</h3>
                        <p>조선왕조실록 스타일로 기록됩니다</p>
                    </div>
                </div>
                <div class="chat-input">
                    <input type="text" id="user-input" placeholder="대화 내용을 입력하세요..." />
                    <button id="send-btn">전송</button>
                    <button id="save-btn">실록 저장</button>
                    <button id="history-btn">기록 보기</button>
                </div>
            </div>
            <div class="sagwan-preview" id="sagwan-preview">
                <h4>실록 미리보기</h4>
                <div id="preview-content"></div>
            </div>
        `;
    }
    
    setupEventListeners() {
        document.getElementById('send-btn').addEventListener('click', () => this.sendMessage());
        document.getElementById('user-input').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') this.sendMessage();
        });
        document.getElementById('save-btn').addEventListener('click', () => this.saveToSagwan());
        document.getElementById('history-btn').addEventListener('click', () => this.loadHistory());
    }
    
    async sendMessage() {
        const input = document.getElementById('user-input');
        const message = input.value.trim();
        
        if (!message) return;
        
        // 사용자 메시지 추가
        this.addMessage('user', message);
        this.conversation.push({ role: 'user', content: message });
        input.value = '';
        
        // LLM 응답 (백엔드 호출)
        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messages: this.conversation })
            });
            const data = await response.json();
            
            this.addMessage('assistant', data.reply);
            this.conversation.push({ role: 'assistant', content: data.reply });
            this.updatePreview();
        } catch (error) {
            console.error('LLM error:', error);
            this.addMessage('assistant', '응답 생성 중 오류가 발생했습니다.');
        }
    }
    
    addMessage(role, content) {
        const history = document.getElementById('chat-history');
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${role}`;
        messageDiv.innerHTML = `
            <div class="message-role">${role === 'user' ? '👤 사용자' : '📜 사관'}</div>
            <div class="message-content">${content}</div>
        `;
        history.appendChild(messageDiv);
        history.scrollTop = history.scrollHeight;
    }
    
    updatePreview() {
        const preview = document.getElementById('preview-content');
        preview.innerHTML = this.generateSagwanTemplate();
    }
    
    generateSagwanTemplate() {
        const today = new Date();
        const dateStr = today.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
        
        let content = `<p>宣祖大王實錄</p>`;
        content += `<p>${dateStr}日</p>`;
        content += `<hr>`;
        
        this.conversation.forEach(msg => {
            if (msg.role === 'user') {
                content += `<p><strong>問:</strong> ${msg.content}</p>`;
            } else {
                content += `<p><strong>答:</strong> ${msg.content}</p>`;
            }
        });
        
        return content;
    }
    
    async saveToSagwan() {
        if (this.conversation.length === 0) {
            alert('대화가 없습니다.');
            return;
        }
        
        try {
            const response = await fetch('/api/sagwan/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    conversation: this.conversation,
                    template: this.generateSagwanTemplate()
                })
            });
            
            if (response.ok) {
                alert('실록 기록이 저장되었습니다!');
            } else {
                alert('저장 실패: ' + response.statusText);
            }
        } catch (error) {
            console.error('Save error:', error);
            alert('저장 중 오류가 발생했습니다.');
        }
    }
    
    async loadHistory() {
        try {
            const response = await fetch('/api/sagwan/history');
            const data = await response.json();
            
            const historyDiv = document.createElement('div');
            historyDiv.className = 'history-modal';
            historyDiv.innerHTML = `
                <h3>과거 기록</h3>
                <div class="history-list">
                    ${data.records.map(record => `
                        <div class="history-item" onclick="loadRecord('${record.id}')">
                            <span class="date">${record.date}</span>
                            <span class="preview">${record.preview}</span>
                        </div>
                    `).join('')}
                </div>
                <button onclick="this.parentElement.remove()">닫기</button>
            `;
            
            document.body.appendChild(historyDiv);
        } catch (error) {
            console.error('History load error:', error);
        }
    }
}
